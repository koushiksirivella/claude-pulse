{
  "manifest_version": 3,
  "name": "Claude Pulse Bridge",
  "version": "0.2.0",
  "description": "Bridges claude.ai's official usage % to the Claude Pulse desktop widget.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://claude.ai/*",
    "http://localhost:7456/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_title": "Claude Pulse Bridge — Active"
  }
}
